<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= plan.name %> — Reserva — Irene Monticelli</title>
<link rel="icon" href="/favicon.ico">
<!-- Stile esatto del sito (_77) -->
<link rel="stylesheet" href="/reserva77.css">
<style>
  body{margin:0;background:#f6f6f4;padding-top:72px}
  /* Header del sito: FISSO in alto (non scorre) — logo a sinistra, voci a destra */
  .rv-site-head{position:fixed;top:0;left:0;right:0;z-index:50;background:#fff;border-bottom:1px solid rgba(0,0,0,.07)}
  .rv-site-head .nav{display:flex;align-items:center;justify-content:space-between;max-width:1280px;margin:0 auto;padding:16px 5vw}
  .rv-site-head .logo{display:block;width:170px;max-width:42vw;color:#1c1f26}
  .rv-site-head .logo svg{display:block;width:100%;height:auto}
  .rv-site-head .logo .cls-1{fill:#e0aa00}
  .rv-site-head .nav-links{display:flex;gap:30px;align-items:center}
  .rv-site-head .nav-links a{color:#1c1f26;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:.01em}
  .rv-site-head .nav-links a:hover{color:#c8970a}
  .rv-burger{display:none;background:none;border:0;cursor:pointer;flex-direction:column;gap:5px;padding:8px}
  .rv-burger span{display:block;width:24px;height:2px;background:#1c1f26}
  @media(max-width:780px){
    .rv-burger{display:flex}
    .rv-site-head .nav-links{position:absolute;top:100%;left:0;right:0;background:#fff;flex-direction:column;gap:0;padding:8px 0;
      border-bottom:1px solid rgba(0,0,0,.08);box-shadow:0 16px 30px -16px rgba(0,0,0,.25);display:none}
    .rv-site-head .nav-links.open{display:flex}
    .rv-site-head .nav-links a{padding:14px 6vw;width:100%}
  }
  .pk-booking{padding:34px 0 70px}
  .rv-formula{display:flex;gap:10px;flex-wrap:wrap}
  .rv-lesson{border:1px solid rgba(0,0,0,.1);border-radius:14px;padding:14px 16px;margin:12px 0}
  .rv-lesson > b{display:block;margin-bottom:8px}
  .rv-consent{display:flex;gap:12px;align-items:flex-start;margin:14px 0;font-size:14px;line-height:1.5}
  .rv-consent input{width:20px;height:20px;margin-top:1px;flex-shrink:0}
  .rv-hide{display:none !important}
  .rv-err{background:#fdecec;border:1px solid #f3c9c9;color:#b53636;padding:12px 16px;border-radius:12px;margin:0 6vw 18px;font-size:14px}
  .pk-pay-row-panel p{margin:.4em 0}
  /* Layout campi uniforme su tutti i pacchetti — stile input NATIVO del sito
     (bordo dorato e fino al focus): non sovrascrivo aspetto/bordo degli input */
  .pk-form .pk-row{display:grid;grid-template-columns:1fr 1fr;gap:22px;align-items:start}
  .pk-form .pk-row.pk-row-1{grid-template-columns:1fr}
  .pk-form .pk-field{min-width:0}
  @media(max-width:680px){.pk-form .pk-row{grid-template-columns:1fr;gap:0}}
  /* Campi = stile elegante del sito: underline, focus dorato e fino */
  .pk-form .pk-field input,.pk-form .pk-field select{
    font-family:inherit;font-weight:300;font-size:17px;color:#2a2a2a;background:transparent;
    border:0;border-bottom:1px solid rgba(42,42,42,.22);border-radius:0;
    padding:14px 0 16px;outline:none;width:100%;box-shadow:none;
    transition:border-bottom-color .35s cubic-bezier(.7,0,.2,1),border-bottom-width .35s cubic-bezier(.7,0,.2,1)}
  .pk-form .pk-field input::placeholder{color:rgba(42,42,42,.32)}
  .pk-form .pk-field input:focus,.pk-form .pk-field select:focus{
    border-bottom-color:#e0aa00;border-bottom-width:1.5px;padding-bottom:15.5px}
  .pk-form .pk-field input[type=date]{color:#2a2a2a}
  /* Niente messaggi d'errore inline (validazione lato server) */
  .pk-form .pk-error{display:none !important}
  /* ===== Checkout: layout pulito e deterministico ===== */
  body{overflow-x:hidden}
  .pk-booking,.pk-booking-wrap{padding-left:0 !important;padding-right:0 !important}
  .pk-booking-wrap{max-width:1140px !important;margin:0 auto !important;padding:0 28px !important;width:100% !important;box-sizing:border-box}
  .pk-checkout-grid{display:grid !important;grid-template-columns:minmax(0,1fr) 380px !important;
    gap:40px !important;align-items:start !important;width:100% !important}
  .pk-checkout-main{min-width:0}
  .pk-checkout-main .pk-form{max-width:none !important;margin:0 !important;width:100% !important}
  .pk-checkout-main,.pk-checkout-main .pk-form{padding-top:0 !important;margin-top:0 !important}
  .pk-checkout-main .pk-form>.pk-block:first-child{padding-top:30px !important;margin-top:0 !important}
  .pk-checkout-main .pk-block-pack{padding-top:30px !important}
  .pk-checkout-main .pk-pack-title{margin:0 !important;padding:0 !important;line-height:1.05}
  /* Riepilogo: NON sticky, larghezza piena della colonna, righe label/valore */
  .pk-summary-sticky{position:static !important;top:auto !important;align-self:start;
    width:100% !important;min-width:0;max-width:none !important;padding:0 !important;margin:0 !important}
  .pk-summary-card{width:100% !important;max-width:none !important;box-sizing:border-box;
    margin:0 !important;padding:30px 28px 26px !important}
  .pk-summary-card .pk-summary-title{margin:0 0 18px !important;padding:0 !important;line-height:1.15;white-space:normal}
  .pk-summary-row,.pk-summary-card .pk-summary-row{display:flex !important;justify-content:space-between;
    align-items:baseline;gap:16px;padding:9px 0}
  .pk-summary-label,.pk-summary-card .pk-summary-label{white-space:nowrap}
  .pk-summary-value,.pk-summary-card .pk-summary-value{text-align:right}
  @media(max-width:900px){
    .pk-checkout-grid{grid-template-columns:1fr !important;gap:26px !important}
    .pk-booking-wrap{max-width:640px !important}
  }
</style>
</head>
<body class="on-pack" data-pack-color="<%= plan.slug.replace('pack-','') %>">
<% if (typeof logoDefs !== 'undefined' && logoDefs) { %><%- logoDefs %><% } %>
<header class="rv-site-head">
  <nav class="nav">
    <a href="/" class="logo" aria-label="Irene Monticelli — Home">
      <svg viewBox="0 0 1000 140" preserveAspectRatio="xMinYMid meet" aria-hidden="true"><use href="#logo-paths"/></svg>
    </a>
    <button class="rv-burger" id="rvBurger" aria-label="Menú"><span></span><span></span><span></span></button>
    <div class="nav-links" id="rvNav">
      <a href="/quien-soy">Quién soy</a>
      <a href="/pro-dance">Pro Dance</a>
      <a href="/contatti">Contacto</a>
    </div>
  </nav>
</header>

<% if (error) { %><div class="rv-err"><%= error %></div><% } %>

<section class="pk-booking">
  <div class="pk-booking-wrap" data-pack-key="<%= plan.slug %>" data-pack-price="<%= currentPrice %>">
    <div class="pk-checkout-grid">
      <!-- COLONNA SINISTRA -->
      <div class="pk-checkout-main">
        <form class="pk-form" id="rvForm" method="post" action="/reserva/<%= plan.slug %>" novalidate
              data-mode="<%= plan.bookingMode %>"
              data-pricing='<%- JSON.stringify(pricing) %>'
              data-days='<%- JSON.stringify(days) %>'
              data-slots='<%- JSON.stringify(slots) %>'
              data-curprice="<%= currentPrice %>">

          <!-- 1. Pack -->
          <section class="pk-block pk-block-pack">
            <h1 class="pk-pack-title"><%= plan.name %></h1>
            <p class="pk-pack-desc"><%= plan.description %></p>
            <% if (others && others.length) { %>
            <details class="pk-change-pack">
              <summary>
                <span>Cambiar de paquete</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pk-change-list">
                <% others.forEach(function(o){ %>
                  <a class="pk-change-option" href="/reserva/<%= o.slug %>">
                    <span class="pk-change-name"><%= o.name %></span>
                    <span class="pk-change-price"><%= o.price %>€</span>
                  </a>
                <% }) %>
              </div>
            </details>
            <% } %>
          </section>

          <!-- 2. Selezione (dipende dalla modalità) -->
          <% if (plan.bookingMode === 'single_lessons') { %>
          <section class="pk-block">
            <h2 class="pk-block-title">Fórmula</h2>
            <div class="pk-sub-label">Elige cuántas clases</div>
            <div class="rv-formula" id="rvFormula" role="radiogroup">
              <% (pricing.options||[]).forEach(function(o,i){ %>
                <button type="button" class="pk-slot rv-opt" data-count="<%= o.count %>" data-price="<%= o.price %>" aria-checked="<%= i===0?'true':'false' %>">
                  <%= o.count %> clase<%= o.count>1?'s':'' %> · <%= o.price %>€
                </button>
              <% }) %>
            </div>
            <input type="hidden" name="count" id="rvCount" value="<%= (pricing.options&&pricing.options[0])?pricing.options[0].count:1 %>">
          </section>
          <section class="pk-block">
            <h2 class="pk-block-title">Fecha y horario de cada clase</h2>
            <div id="rvLessons"></div>
          </section>
          <% } else if (plan.bookingMode === 'red') { %>
          <section class="pk-block">
            <h2 class="pk-block-title">Para cada día: mañana o tarde</h2>
            <% days.forEach(function(d){ %>
              <div class="pk-block" style="border:0;padding:0;margin:14px 0">
                <div class="pk-sub-label"><%= d.dow %> <%= d.num %> <%= d.mon %></div>
                <div class="pk-slots-row rv-ampm" data-day="<%= d.iso %>" role="radiogroup">
                  <button type="button" class="pk-slot" data-val="AM" aria-checked="false">Mañana</button>
                  <button type="button" class="pk-slot" data-val="PM" aria-checked="false">Tarde</button>
                </div>
                <input type="hidden" name="day_<%= d.iso %>" value="">
              </div>
            <% }) %>
          </section>
          <% } else if (plan.bookingMode === 'junior') { %>
          <section class="pk-block">
            <h2 class="pk-block-title">Programa</h2>
            <p class="pk-pack-desc">Todos los días por la mañana, de <strong>9:30 a 12:30</strong> (<%= days.length %> días). No hay que elegir horario.</p>
          </section>
          <% } else { %>
          <section class="pk-block">
            <h2 class="pk-block-title">Programa</h2>
            <p class="pk-pack-desc">Acceso libre a todas las clases de los <%= days.length %> días. No hay que elegir nada.</p>
          </section>
          <% } %>

          <!-- 3. Datos -->
          <section class="pk-block">
            <h2 class="pk-block-title">Tus datos</h2>
            <div class="pk-row">
              <div class="pk-field"><input type="text" name="firstName" required autocomplete="given-name" placeholder="Nombre"><span class="pk-error" data-error>Campo obligatorio</span></div>
              <div class="pk-field"><input type="text" name="lastName" required autocomplete="family-name" placeholder="Apellidos"><span class="pk-error" data-error>Campo obligatorio</span></div>
            </div>
            <div class="pk-row">
              <div class="pk-field"><input type="email" name="email" required autocomplete="email" placeholder="Email"><span class="pk-error" data-error>Email no válido</span></div>
              <div class="pk-field"><input type="tel" name="phone" required autocomplete="tel" placeholder="Teléfono"><span class="pk-error" data-error>Teléfono obligatorio</span></div>
            </div>
            <div class="pk-row pk-row-1">
              <div class="pk-field">
                <label class="pk-sub-label" for="rvBd">Fecha de nacimiento</label>
                <input type="date" id="rvBd" name="birthDate" required>
                <span class="pk-error" data-error>Fecha obligatoria</span>
              </div>
            </div>

            <div class="rv-consent rv-hide" id="rvParentBox">
              <input type="checkbox" name="parentalConsent" id="rvPc">
              <label for="rvPc">Soy el padre/madre/tutor legal y <strong>autorizo la participación del menor</strong> (obligatorio para menores de 18 años).</label>
            </div>
            <div class="rv-consent">
              <input type="checkbox" name="imageConsent" id="rvIc" required>
              <label for="rvIc">Autorizo el uso de <strong>imágenes y vídeos</strong> de la actividad con fines de comunicación (obligatorio).</label>
            </div>
          </section>

          <!-- 4. Método de pago (visivo come _77; il pago reale è seguro vía Stripe) -->
          <section class="pk-block">
            <h2 class="pk-block-title">Método de pago</h2>
            <div class="pk-pay-stack" role="tablist">
              <div class="pk-pay-row is-active" data-method-row="card">
                <button type="button" class="pk-pay-row-head" data-method="card" role="tab" aria-selected="true">
                  <span class="pk-pay-radio"><span class="pk-pay-radio-dot"></span></span>
                  <span class="pk-pay-row-label">Tarjeta</span>
                  <span class="pk-pay-row-badges">
                    <span class="pk-pay-badge pk-badge-visa">VISA</span>
                    <span class="pk-pay-badge pk-badge-mc">MC</span>
                    <span class="pk-pay-badge pk-badge-amex">AMEX</span>
                    <span class="pk-pay-badge pk-badge-more">+5</span>
                  </span>
                </button>
                <div class="pk-pay-row-panel"><p class="pk-pay-info">Pago seguro con tarjeta. Serás redirigido a la pasarela cifrada de Stripe para completar el pago.</p></div>
              </div>
              <div class="pk-pay-row" data-method-row="other">
                <button type="button" class="pk-pay-row-head" data-method="other" role="tab" aria-selected="false">
                  <span class="pk-pay-radio"><span class="pk-pay-radio-dot"></span></span>
                  <span class="pk-pay-row-label">Otros métodos</span>
                </button>
                <div class="pk-pay-row-panel"><p class="pk-pay-info">En la pasarela de pago podrás elegir otros métodos disponibles.</p></div>
              </div>
            </div>
          </section>

          <div class="pk-confirm-left">
            <button type="submit" class="pk-confirm-final is-disabled" id="rvSubmitL">Confirmar y pagar</button>
          </div>
        </form>
      </div>

      <!-- COLONNA DESTRA: summary sticky -->
      <aside class="pk-summary-sticky">
        <div class="pk-summary-card">
          <h3 class="pk-summary-title">Resumen de tu reserva</h3>
          <div class="pk-summary-rows">
            <div class="pk-summary-row"><span class="pk-summary-label">Paquete</span><span class="pk-summary-value"><%= plan.name %></span></div>
            <div class="pk-summary-row"><span class="pk-summary-label">Evento</span><span class="pk-summary-value"><%= event ? event.title : '' %></span></div>
            <div class="pk-summary-row"><span class="pk-summary-label">Detalle</span><span class="pk-summary-value pk-summary-empty" id="rvSumDetail">—</span></div>
          </div>
          <div class="pk-summary-total">
            <span class="pk-summary-total-label">Total</span>
            <span class="pk-summary-total-amount" id="rvTotal"><%= currentPrice %>€</span>
          </div>
          <button type="submit" form="rvForm" class="pk-confirm-final is-disabled" id="rvSubmitR">Confirmar y pagar</button>
          <div class="pk-secure-note">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1l9 4v6c0 5.5-4 10.7-9 12-5-1.3-9-6.5-9-12V5l9-4z"/></svg>
            Pago seguro · cifrado SSL · Stripe
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
(function(){
  var bg=document.getElementById('rvBurger'),nv=document.getElementById('rvNav');
  if(bg&&nv){bg.addEventListener('click',function(){nv.classList.toggle('open');});
    nv.addEventListener('click',function(e){if(e.target.tagName==='A')nv.classList.remove('open');});}
})();
(function(){
  var form=document.getElementById('rvForm');
  var mode=form.dataset.mode;
  var pricing=JSON.parse(form.dataset.pricing||'{}');
  var DAYS=JSON.parse(form.dataset.days||'[]');
  var SLOTS=JSON.parse(form.dataset.slots||'[]');
  var curPrice=parseFloat(form.dataset.curprice)||0;
  var totalEl=document.getElementById('rvTotal');
  var detEl=document.getElementById('rvSumDetail');
  var subs=[document.getElementById('rvSubmitL'),document.getElementById('rvSubmitR')];
  var total=curPrice;

  function datePills(){return DAYS.map(function(d){return '<button type="button" class="pk-date" data-date="'+d.iso+'" role="radio" aria-checked="false"><span class="pk-date-day">'+d.dow+'</span><span class="pk-date-num">'+d.num+'</span></button>';}).join('');}
  function slotPills(){return SLOTS.map(function(s){return '<button type="button" class="pk-slot" data-slot="'+s+'" role="radio" aria-checked="false">'+s+'</button>';}).join('');}

  // Single: fórmula + N lezioni
  if(mode==='single_lessons'){
    var opts=document.querySelectorAll('.rv-opt');
    var countInp=document.getElementById('rvCount');
    var box=document.getElementById('rvLessons');
    function renderLessons(n){
      var h='';
      for(var i=0;i<n;i++){
        h+='<div class="rv-lesson"><b>Clase '+(i+1)+'</b>'+
           '<div class="pk-sub-label">Fecha</div><div class="pk-dates rv-d" data-i="'+i+'">'+datePills()+'</div>'+
           '<div class="pk-sub-label pk-sub-label-spaced">Horario</div><div class="pk-slots-row rv-s" data-i="'+i+'">'+slotPills()+'</div>'+
           '<input type="hidden" name="lesson_day_'+i+'" value=""><input type="hidden" name="lesson_slot_'+i+'" value=""></div>';
      }
      box.innerHTML=h;
    }
    function selOpt(btn){
      opts.forEach(function(o){o.classList.remove('is-selected');o.setAttribute('aria-checked','false');});
      btn.classList.add('is-selected');btn.setAttribute('aria-checked','true');
      countInp.value=btn.dataset.count;
      total=parseFloat(btn.dataset.price)||0;
      renderLessons(parseInt(btn.dataset.count,10));
      sync();
    }
    opts.forEach(function(o){o.addEventListener('click',function(){selOpt(o);});});
    if(opts[0]) selOpt(opts[0]);
    box.addEventListener('click',function(e){
      var dt=e.target.closest('.pk-date'), sl=e.target.closest('.pk-slot');
      if(dt){var c=dt.closest('.rv-d');c.querySelectorAll('.pk-date').forEach(function(x){x.classList.remove('is-selected');x.setAttribute('aria-checked','false');});dt.classList.add('is-selected');dt.setAttribute('aria-checked','true');c.parentNode.querySelector('input[name="lesson_day_'+c.dataset.i+'"]').value=dt.dataset.date;sync();}
      if(sl){var c2=sl.closest('.rv-s');c2.querySelectorAll('.pk-slot').forEach(function(x){x.classList.remove('is-selected');x.setAttribute('aria-checked','false');});sl.classList.add('is-selected');sl.setAttribute('aria-checked','true');c2.parentNode.querySelector('input[name="lesson_slot_'+c2.dataset.i+'"]').value=sl.dataset.slot;sync();}
    });
  }

  // Red: AM/PM per giorno
  if(mode==='red'){
    document.querySelectorAll('.rv-ampm').forEach(function(row){
      row.addEventListener('click',function(e){
        var b=e.target.closest('.pk-slot'); if(!b)return;
        row.querySelectorAll('.pk-slot').forEach(function(x){x.classList.remove('is-selected');x.setAttribute('aria-checked','false');});
        b.classList.add('is-selected');b.setAttribute('aria-checked','true');
        row.parentNode.querySelector('input[name="day_'+row.dataset.day+'"]').value=b.dataset.val;
        sync();
      });
    });
  }

  // Metodo pagamento (solo visivo)
  document.querySelectorAll('.pk-pay-row-head').forEach(function(h){
    h.addEventListener('click',function(){
      document.querySelectorAll('.pk-pay-row').forEach(function(r){r.classList.remove('is-active');});
      document.querySelectorAll('.pk-pay-row-head').forEach(function(x){x.setAttribute('aria-selected','false');});
      h.closest('.pk-pay-row').classList.add('is-active');h.setAttribute('aria-selected','true');
    });
  });

  // Età -> consenso genitori
  var bd=document.getElementById('rvBd'),pbox=document.getElementById('rvParentBox'),pc=document.getElementById('rvPc');
  function checkAge(){
    if(!bd.value){pbox.classList.add('rv-hide');pc.required=false;pc.checked=false;sync();return;}
    var b=new Date(bd.value),n=new Date(),a=n.getFullYear()-b.getFullYear(),m=n.getMonth()-b.getMonth();
    if(m<0||(m===0&&n.getDate()<b.getDate()))a--;
    if(a<18){pbox.classList.remove('rv-hide');pc.required=true;}else{pbox.classList.add('rv-hide');pc.required=false;pc.checked=false;}
    sync();
  }
  bd.addEventListener('change',checkAge);

  function selectionOk(){
    if(mode==='single_lessons'){
      var n=parseInt(document.getElementById('rvCount').value,10);
      for(var i=0;i<n;i++){var d=form.querySelector('input[name="lesson_day_'+i+'"]'),s=form.querySelector('input[name="lesson_slot_'+i+'"]');if(!d||!s||!d.value||!s.value)return false;}
      return true;
    }
    if(mode==='red'){var rows=document.querySelectorAll('.rv-ampm');for(var k=0;k<rows.length;k++){var inp=rows[k].parentNode.querySelector('input');if(!inp.value)return false;}return true;}
    return true;
  }
  function fieldsOk(){
    var fn=form.firstName.value.trim(),ln=form.lastName.value.trim(),em=form.email.value.trim(),ph=form.phone.value.trim();
    if(fn.length<2||ln.length<2||!ph||!bd.value)return false;
    if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em))return false;
    if(!document.getElementById('rvIc').checked)return false;
    if(pc.required&&!pc.checked)return false;
    return true;
  }
  function sync(){
    // dettaglio + totale
    var det='—';
    if(mode==='single_lessons'){var n=parseInt(document.getElementById('rvCount').value,10);det=n+' clase'+(n>1?'s':'');}
    else if(mode==='red'){det='3 clases/día · '+DAYS.length+' días';}
    else if(mode==='junior'){det='Mañanas 9:30–12:30 · '+DAYS.length+' días';}
    else{det='Open class · '+DAYS.length+' días';}
    detEl.textContent=det; detEl.classList.remove('pk-summary-empty');
    totalEl.textContent=(total||curPrice)+'€';
    var ready=selectionOk()&&fieldsOk();
    subs.forEach(function(b){ if(ready){b.classList.remove('is-disabled');}else{b.classList.add('is-disabled');} });
  }
  form.addEventListener('input',sync);
  form.addEventListener('change',sync);
  form.addEventListener('submit',function(e){
    if(!(selectionOk()&&fieldsOk())){e.preventDefault();sync();window.scrollTo({top:0,behavior:'smooth'});}
  });
  checkAge(); sync();
})();
</script>
