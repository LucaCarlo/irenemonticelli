<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Profesores — Irene Monticelli</title>
<meta name="description" content="El equipo de profesores de la Pro Dance Experience.">
<link rel="icon" href="/favicon.ico">
<link rel="stylesheet" href="/reserva77.css">
<style>
  body{margin:0;background:#f3f1ec;color:#1c1f26;font-family:'Manrope',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;padding-top:72px}
  .pf-head{position:fixed;top:0;left:0;right:0;z-index:50;background:#fff;border-bottom:1px solid rgba(0,0,0,.07)}
  .pf-head .nav{display:flex;align-items:center;justify-content:space-between;max-width:1280px;margin:0 auto;padding:16px 5vw}
  .pf-head .logo{display:block;width:170px;max-width:42vw;color:#1c1f26}
  .pf-head .logo svg{display:block;width:100%;height:auto}
  .pf-head .logo .cls-1{fill:#e0aa00}
  .pf-head .nav-links{display:flex;gap:30px;align-items:center}
  .pf-head .nav-links a{color:#1c1f26;text-decoration:none;font-size:14px;font-weight:600}
  .pf-head .nav-links a:hover{color:#c8970a}
  .pf-burger{display:none;background:none;border:0;cursor:pointer;flex-direction:column;gap:5px;padding:8px}
  .pf-burger span{display:block;width:24px;height:2px;background:#1c1f26}
  @media(max-width:780px){.pf-burger{display:flex}.pf-head .nav-links{position:absolute;top:100%;left:0;right:0;background:#fff;flex-direction:column;gap:0;padding:8px 0;border-bottom:1px solid rgba(0,0,0,.08);display:none}.pf-head .nav-links.open{display:flex}.pf-head .nav-links a{padding:14px 6vw}}
  .pf-hero{max-width:1100px;margin:0 auto;padding:64px 6vw 14px;text-align:center}
  .pf-kick{text-transform:uppercase;letter-spacing:.3em;font-size:12px;color:#9a8f7a;margin-bottom:14px}
  .pf-hero h1{font-family:'Fraunces',Georgia,serif;font-weight:600;font-size:clamp(34px,5vw,60px);margin:0}
  .pf-hero h1 em{font-style:italic;color:#b88a1a}
  .pf-hero p{color:#52555c;max-width:60ch;margin:16px auto 0;font-size:17px;line-height:1.7}
  .pf-grid{max-width:1180px;margin:40px auto 90px;padding:0 6vw;display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:34px}
  .pf-card{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 50px -34px rgba(0,0,0,.3)}
  .pf-photo{aspect-ratio:4/5;background:#e7e4dd;overflow:hidden}
  .pf-photo img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .9s ease}
  .pf-card:hover .pf-photo img{transform:scale(1.05)}
  .pf-body{padding:24px 24px 28px}
  .pf-name{font-family:'Fraunces',Georgia,serif;font-size:25px;font-weight:600;margin:0}
  .pf-type{color:#b88a1a;font-size:13px;letter-spacing:.12em;text-transform:uppercase;margin:6px 0 14px}
  .pf-desc{font-size:14.5px;line-height:1.7;color:#3a3d44}
  .pf-desc p{margin:0 0 .7em}
  .pf-cta{text-align:center;padding:0 6vw 90px}
  .pf-cta a{display:inline-block;background:#1c1f26;color:#fff;text-decoration:none;font-weight:700;padding:15px 30px;border-radius:40px}
  .pf-empty{text-align:center;color:#7a8190;padding:60px 20px}
  footer.pf-foot{padding:40px 6vw;border-top:1px solid rgba(0,0,0,.08);text-align:center;color:#7a8190;font-size:13px}
  footer.pf-foot a{margin:0 10px;text-decoration:none}
</style>
</head>
<body>
<% if (typeof logoDefs !== 'undefined' && logoDefs) { %><%- logoDefs %><% } %>
<header class="pf-head">
  <nav class="nav">
    <a href="/" class="logo" aria-label="Irene Monticelli"><svg viewBox="0 0 1000 140" preserveAspectRatio="xMinYMid meet" aria-hidden="true"><use href="#logo-paths"/></svg></a>
    <button class="pf-burger" id="pfBurger" aria-label="Menú"><span></span><span></span><span></span></button>
    <div class="nav-links" id="pfNav">
      <a href="/quien-soy">Quién soy</a>
      <a href="/pro-dance">Pro Dance</a>
      <a href="/profesores">Profesores</a>
      <a href="/contatti">Contacto</a>
    </div>
  </nav>
</header>

<section class="pf-hero">
  <div class="pf-kick">Pro Dance Experience</div>
  <h1>Nuestros <em>profesores</em></h1>
  <p>Un equipo de docentes que acompaña cada jornada de trabajo: técnica, lenguaje y presencia escénica.</p>
</section>

<% if (!profs.length) { %>
  <div class="pf-empty">Pronto publicaremos el equipo de profesores.</div>
<% } else { %>
<section class="pf-grid">
  <% profs.forEach(function(p){ %>
    <article class="pf-card">
      <div class="pf-photo">
        <% if (p.photo) { %><img loading="lazy" src="<%= p.photo.path %>" alt="<%= p.firstName %> <%= p.lastName %>"><% } %>
      </div>
      <div class="pf-body">
        <h2 class="pf-name"><%= p.firstName %> <%= p.lastName %></h2>
        <% if (p.danceType) { %><div class="pf-type"><%= p.danceType %></div><% } %>
        <div class="pf-desc"><%- p.descriptionHtml %></div>
      </div>
    </article>
  <% }) %>
</section>
<% } %>

<div class="pf-cta"><a href="/pro-dance">Descubre la Pro Dance Experience</a></div>

<footer class="pf-foot">
  <div><a href="/quien-soy">Quién soy</a> · <a href="/pro-dance">Pro Dance</a> · <a href="/profesores">Profesores</a> · <a href="/contatti">Escríbenos</a></div>
  <div style="margin-top:10px">© <span id="y"></span> Irene Monticelli</div>
</footer>
<script>
  document.getElementById('y').textContent=new Date().getFullYear();
  (function(){var b=document.getElementById('pfBurger'),n=document.getElementById('pfNav');
   if(b&&n){b.addEventListener('click',function(){n.classList.toggle('open');});}})();
</script>
</body>
</html>
