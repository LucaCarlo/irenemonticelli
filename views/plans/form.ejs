<%- include('../partials/header') %>
<div class="card form-card wide">
  <h2><%= plan ? 'Modifica piano' : 'Nuovo piano' %></h2>
  <form method="post" action="<%= plan ? '/admin/plans/'+plan.id : '/admin/plans' %>" class="form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-grid">
      <div class="field"><label class="field-lbl">Nome</label><input type="text" name="name" required value="<%= plan ? plan.name : '' %>"></div>
      <div class="field"><label class="field-lbl">Slug</label><input type="text" name="slug" required value="<%= plan ? plan.slug : '' %>" placeholder="es. pack-gold"><div class="field-help">Collega il pacchetto al sito.</div></div>
      <div class="field">
        <label class="field-lbl">Evento</label>
        <select name="eventId">
          <option value="">— Nessuno —</option>
          <% events.forEach(function(ev){ %>
            <option value="<%= ev.id %>" <%= plan && plan.eventId===ev.id ? 'selected':'' %>><%= ev.title %></option>
          <% }) %>
        </select>
        <div class="field-help">L'evento a cui appartiene questo pacchetto.</div>
      </div>
      <div class="field"><label class="field-lbl">Prezzo</label><input type="number" step="0.01" name="price" value="<%= plan ? plan.price : 0 %>"></div>
      <div class="field"><label class="field-lbl">Valuta</label><input type="text" name="currency" value="<%= plan ? plan.currency : 'EUR' %>"></div>
      <div class="field">
        <label class="field-lbl">Colore</label>
        <div class="color-row">
          <input type="color" name="color" value="<%= plan ? (plan.color||'#e0aa00') : '#e0aa00' %>">
          <input type="text" class="color-hex" value="<%= plan ? (plan.color||'#e0aa00') : '#e0aa00' %>" readonly>
        </div>
      </div>
      <div class="field"><label class="field-lbl">Badge (opzionale)</label><input type="text" name="badge" value="<%= plan ? plan.badge : '' %>" placeholder="es. Mas popular"></div>
      <div class="field"><label class="field-lbl">Etichetta bottone</label><input type="text" name="ctaLabel" value="<%= plan ? plan.ctaLabel : 'Reserva' %>"></div>
      <div class="field">
        <label class="field-lbl">Comportamento prenotazione</label>
        <select name="bookingMode">
          <% MODES.forEach(function(m){ %><option value="<%= m.v %>" <%= plan && plan.bookingMode===m.v ? 'selected':'' %>><%= m.l %></option><% }) %>
        </select>
      </div>
      <div class="field"><label class="field-lbl">Ordine</label><input type="number" name="sort" value="<%= plan ? plan.sort : 0 %>"></div>
      <div class="field field-full"><label class="field-lbl">Descrizione</label><textarea name="description" rows="3"><%= plan ? plan.description : '' %></textarea></div>
      <div class="field field-full">
        <label class="field-lbl">Prezzi (JSON)</label>
        <textarea name="pricingJson" rows="4" style="font-family:monospace;font-size:13px"><%= plan ? plan.pricingJson : '' %></textarea>
        <div class="field-help">
          Single (lezioni): <code>{"type":"lessons","options":[{"count":1,"price":35},{"count":3,"price":82.5},{"count":6,"price":120}]}</code><br>
          Gold/Red/Junior (fasce): <code>{"type":"tiers","base":360,"tiers":[{"until":"2026-06-15","price":288},{"until":"2026-07-10","price":324}]}</code> — prezzo = fascia attiva in base alla data, altrimenti <code>base</code>.
        </div>
      </div>
      <div class="field"><label class="switch"><input type="checkbox" name="active" value="1" <%= !plan || plan.active ? 'checked':'' %>><span>Attivo (visibile)</span></label></div>
    </div>
    <div class="form-actions">
      <button class="btn btn-primary"><%= plan ? 'Salva' : 'Crea' %></button>
      <a class="btn btn-ghost" href="/admin/plans">Annulla</a>
    </div>
  </form>
</div>
<script>
  document.querySelectorAll('.color-row').forEach(function(r){
    var c=r.querySelector('input[type=color]'), t=r.querySelector('.color-hex');
    c.addEventListener('input',function(){ t.value=c.value; });
  });
</script>
<%- include('../partials/footer') %>
