<%- include('../partials/header') %>
<div class="card">
  <div class="card-head">
    <h2>Piani / Pacchetti</h2>
    <a class="btn btn-primary" href="/admin/plans/new">+ Nuovo piano</a>
  </div>
  <% if (!plans.length) { %><p class="muted">Nessun piano. Creane uno.</p><% } else { %>
  <div class="table-wrap">
  <table class="table">
    <thead><tr><th>Nome</th><th>Slug</th><th>Prezzo</th><th>Prenotazione</th><th>CTA</th><th>Stato</th><th></th></tr></thead>
    <tbody>
    <% plans.forEach(function(p){ var mode=(MODES.find(function(m){return m.v===p.bookingMode;})||{}).l||p.bookingMode; %>
      <tr>
        <td><%= p.name %><% if (p.badge) { %> <span class="badge badge-warn"><%= p.badge %></span><% } %></td>
        <td><code><%= p.slug %></code></td>
        <td><%= p.price %> <%= p.currency %></td>
        <td><%= mode %></td>
        <td><%= p.ctaLabel %></td>
        <td><% if (p.active) { %><span class="badge badge-ok">attivo</span><% } else { %><span class="badge badge-off">nascosto</span><% } %></td>
        <td class="row-actions">
          <a class="btn btn-ghost btn-sm" href="/admin/plans/<%= p.id %>/edit">Modifica</a>
          <form method="post" action="/admin/plans/<%= p.id %>/toggle"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-ghost btn-sm"><%= p.active ? 'Nascondi' : 'Attiva' %></button></form>
          <form method="post" action="/admin/plans/<%= p.id %>/delete" onsubmit="return confirm('Eliminare questo piano?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-danger btn-sm">Elimina</button></form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
