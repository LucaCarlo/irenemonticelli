<%- include('../partials/header') %>
<div class="card">
  <div class="card-head">
    <h2>Professori</h2>
    <a class="btn btn-primary" href="/admin/professors/new">+ Nuovo professore</a>
  </div>
  <% if (!profs.length) { %><p class="muted">Nessun professore. Creane uno.</p><% } else { %>
  <div class="table-wrap">
  <table class="table">
    <thead><tr><th></th><th>Nome</th><th>Tipo di danza</th><th>Stato</th><th></th></tr></thead>
    <tbody>
    <% profs.forEach(function(p){ %>
      <tr>
        <td>
          <% if (p.photo) { %><img src="<%= p.photo.smallPath || p.photo.path %>" alt="" style="width:46px;height:46px;border-radius:50%;object-fit:cover">
          <% } else { %><span class="color-dot" style="width:46px;height:46px;background:#e7e9ee"></span><% } %>
        </td>
        <td><strong><%= p.firstName %> <%= p.lastName %></strong></td>
        <td><%= p.danceType || '—' %></td>
        <td><% if (p.active) { %><span class="badge badge-ok">attivo</span><% } else { %><span class="badge badge-off">nascosto</span><% } %></td>
        <td class="row-actions">
          <a class="btn btn-ghost btn-sm" href="/admin/professors/<%= p.id %>/edit">Modifica</a>
          <form method="post" action="/admin/professors/<%= p.id %>/toggle"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-ghost btn-sm"><%= p.active ? 'Nascondi' : 'Attiva' %></button></form>
          <form method="post" action="/admin/professors/<%= p.id %>/delete" onsubmit="return confirm('Eliminare questo professore?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-danger btn-sm">Elimina</button></form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
