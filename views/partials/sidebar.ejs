<%
  function isActive(prefix){ return (path === prefix || (prefix !== '/admin' && path.indexOf(prefix) === 0)); }
  var cu = currentUser || {};
  var roleName = cu.role ? cu.role.name : '';
%>
<div class="sb-backdrop" id="sbBackdrop"></div>
<aside class="sidebar" id="sidebar">
  <div class="sb-brand">
    <% if (logoUrl) { %>
      <img src="<%= logoUrl %>" alt="<%= appName %>" class="sb-logo-img">
    <% } else { %>
      <div class="sb-logo-txt"><%= appName %></div>
    <% } %>
  </div>

  <nav class="sb-nav">
    <div class="sb-group">
      <div class="sb-group-title">Panoramica</div>
      <a class="sb-link <%= path === '/admin' ? 'active' : '' %>" href="/admin"><%- include('icon',{name:'dashboard'}) %><span>Dashboard</span></a>
    </div>

    <div class="sb-group">
      <div class="sb-group-title">Contenuti</div>
      <% if (can('events.manage')) { %>
        <a class="sb-link <%= isActive('/admin/events') ? 'active' : '' %>" href="/admin/events"><%- include('icon',{name:'events'}) %><span>Eventi</span></a>
      <% } %>
      <span class="sb-link disabled"><%- include('icon',{name:'pages'}) %><span>Pagine</span><em class="soon">presto</em></span>
      <% if (can('media.view')) { %>
        <a class="sb-link <%= isActive('/admin/media') ? 'active' : '' %>" href="/admin/media"><%- include('icon',{name:'media'}) %><span>Media</span></a>
      <% } %>
    </div>

    <div class="sb-group">
      <div class="sb-group-title">Prenotazioni</div>
      <% if (can('plans.manage')) { %>
        <a class="sb-link <%= isActive('/admin/plans') ? 'active' : '' %>" href="/admin/plans"><%- include('icon',{name:'plans'}) %><span>Piani / Pacchetti</span></a>
      <% } %>
      <% if (can('bookings.manage')) { %>
        <a class="sb-link <%= isActive('/admin/bookings') ? 'active' : '' %>" href="/admin/bookings"><%- include('icon',{name:'bookings'}) %><span>Prenotazioni</span></a>
      <% } %>
      <span class="sb-link disabled"><%- include('icon',{name:'calendar'}) %><span>Calendario</span><em class="soon">presto</em></span>
    </div>

    <div class="sb-group">
      <div class="sb-group-title">Comunicazione</div>
      <span class="sb-link disabled"><%- include('icon',{name:'newsletter'}) %><span>Newsletter</span><em class="soon">presto</em></span>
      <span class="sb-link disabled"><%- include('icon',{name:'messages'}) %><span>Messaggi contatto</span><em class="soon">presto</em></span>
    </div>

    <div class="sb-group">
      <div class="sb-group-title">Amministrazione</div>
      <% if (can('users.view')) { %>
        <a class="sb-link <%= isActive('/admin/users') ? 'active' : '' %>" href="/admin/users"><%- include('icon',{name:'users'}) %><span>Utenti admin</span></a>
      <% } %>
      <% if (can('roles.view')) { %>
        <a class="sb-link <%= isActive('/admin/roles') ? 'active' : '' %>" href="/admin/roles"><%- include('icon',{name:'roles'}) %><span>Ruoli</span></a>
      <% } %>
      <% if (can('settings.view')) { %>
        <a class="sb-link <%= path === '/admin/settings' ? 'active' : '' %>" href="/admin/settings"><%- include('icon',{name:'settings'}) %><span>Impostazioni</span></a>
      <% } %>
    </div>

    <div class="sb-group">
      <div class="sb-group-title">Sistema</div>
      <% if (can('stats.view')) { %>
        <a class="sb-link <%= isActive('/admin/settings/stats') ? 'active' : '' %>" href="/admin/settings/stats"><%- include('icon',{name:'stats'}) %><span>Statistiche</span></a>
      <% } %>
      <% if (can('backup.manage')) { %>
        <a class="sb-link <%= isActive('/admin/settings/backup') ? 'active' : '' %>" href="/admin/settings/backup"><%- include('icon',{name:'backup'}) %><span>Backup</span></a>
      <% } %>
      <span class="sb-link disabled"><%- include('icon',{name:'logs'}) %><span>Log attivita</span><em class="soon">presto</em></span>
    </div>
  </nav>

  <div class="sb-user">
    <div class="sb-user-info">
      <div class="sb-avatar"><%= (cu.name || '?').trim().charAt(0).toUpperCase() %></div>
      <div class="sb-user-meta">
        <div class="sb-user-name"><%= cu.name || '' %></div>
        <div class="sb-user-role"><%= roleName %></div>
      </div>
    </div>
    <form method="post" action="/admin/logout" class="sb-logout-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="sb-logout">Esci</button>
    </form>
  </div>
</aside>
