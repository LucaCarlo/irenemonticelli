<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Cambia password</title>
<link rel="icon" href="/favicon.ico">
<link rel="stylesheet" href="/public-admin/css/admin.css">
</head>
<body class="auth-body">
  <div class="auth-card">
    <div class="auth-brand">Cambia password</div>
    <div class="auth-sub">Per sicurezza imposta una nuova password</div>
    <% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>
    <form method="post" action="/admin/change-password" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Password attuale
        <input type="password" name="currentPassword" required autocomplete="current-password">
      </label>
      <label>Nuova password (min 8 caratteri)
        <input type="password" name="newPassword" required minlength="8" autocomplete="new-password">
      </label>
      <label>Conferma nuova password
        <input type="password" name="confirmPassword" required minlength="8" autocomplete="new-password">
      </label>
      <button type="submit" class="btn btn-primary btn-block">Aggiorna password</button>
    </form>
  </div>
</body>
</html>
