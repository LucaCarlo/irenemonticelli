# Copia in .env e personalizza
NODE_ENV=development
PORT=3017

# Segreto sessioni (cambia in produzione!)
SESSION_SECRET=cambia-questo-segreto-lungo-e-casuale

# Database SQLite (Prisma)
DATABASE_URL="file:../data/app.db"

# Super-admin seedato al primo avvio (se non esiste nessun utente)
SEED_ADMIN_EMAIL=luca@mywebagency.com
SEED_ADMIN_NAME=Luca Carlorecchio
# Se vuoto, viene generata una password temporanea e stampata in console
SEED_ADMIN_PASSWORD=

# Limite upload (MB)
MAX_UPLOAD_MB=15
