// Schema Prisma — SQLite. Backup = copia del file data/app.db.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  name               String
  passwordHash       String
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  roleId             Int
  role               Role      @relation(fields: [roleId], references: [id])
  mediaUploaded      Media[]   @relation("MediaUploader")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @default("")
  // Array di chiavi permesso serializzato in JSON. "*" = tutti i permessi.
  permissions String   @default("[]")
  isSystem    Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String   @default("")
  group     String   @default("general")
  updatedAt DateTime @updatedAt
}

model Media {
  id            Int      @id @default(autoincrement())
  filename      String   @unique // base senza estensione, es. 1715000000-foto
  originalName  String
  title         String   @default("")
  alt           String   @default("")
  mime          String   @default("image/webp")
  ext           String   @default("webp")
  width         Int      @default(0)
  height        Int      @default(0)
  sizeBytes     Int      @default(0) // variante "normal"
  smallBytes    Int      @default(0) // variante "small"
  path          String   // url pubblico variante normal, es. /uploads/xxx.webp
  smallPath     String   // url pubblico variante small
  isImage       Boolean  @default(true)
  uploadedById  Int?
  uploadedBy    User?    @relation("MediaUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
}

model Plan {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  price       Float     @default(0)
  currency    String    @default("EUR")
  badge       String    @default("")
  color       String    @default("#e0aa00")
  description String    @default("")
  // single_lessons = scegli 1/3/6 lezioni, giorno+orario per lezione
  // gold = nessuna scelta, prezzo a fasce | red = per giorno mattina/pomeriggio, prezzo a fasce
  // junior = nessuna scelta (mattine fisse), prezzo a fasce
  bookingMode String    @default("single_lessons")
  // JSON prezzi: {"type":"lessons","options":[{"count":1,"price":35}...]}
  //          oppure {"type":"tiers","base":360,"tiers":[{"until":"2026-06-15","price":288}...]}
  pricingJson String    @default("")
  ctaLabel    String    @default("Reserva")
  active      Boolean   @default(true)
  sort        Int       @default(0)
  eventId     Int?
  event       Event?    @relation(fields: [eventId], references: [id])
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  subtitle    String    @default("")
  startDate   DateTime?
  endDate     DateTime?
  location    String    @default("")
  description String    @default("")
  // Orari modificabili da dashboard: JSON array, es. ["9:30","11:15","12:30","15:30","16:45","18:00"]
  slotsJson   String    @default("")
  active      Boolean   @default(true)
  sort        Int       @default(0)
  plans       Plan[]
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id            Int      @id @default(autoincrement())
  customerName  String   @default("")
  firstName     String   @default("")
  lastName      String   @default("")
  customerEmail String
  phone         String   @default("")
  birthDate     DateTime?
  isMinor       Boolean  @default(false)
  parentalConsent Boolean @default(false)
  imageConsent  Boolean  @default(false)
  dataConsent   Boolean  @default(false)
  healthConsent Boolean  @default(false)
  planId        Int?
  plan          Plan?    @relation(fields: [planId], references: [id])
  eventId       Int?
  event         Event?   @relation(fields: [eventId], references: [id])
  dateLabel     String   @default("")
  slot          String   @default("")
  // dettaglio selezione (lezioni/giorni/slot) JSON
  itemsJson     String   @default("")
  method        String   @default("")
  amount        Float    @default(0)
  currency      String   @default("EUR")
  // pending | confirmed | cancelled
  status        String   @default("pending")
  // unpaid | paid | failed | refunded
  paymentStatus String   @default("unpaid")
  stripeSessionId String @default("")
  stripePaymentIntent String @default("")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Professor {
  id              Int      @id @default(autoincrement())
  firstName       String
  lastName        String
  danceType       String   @default("")
  descriptionHtml String   @default("")
  photoMediaId    Int?
  active          Boolean  @default(true)
  sort            Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}
