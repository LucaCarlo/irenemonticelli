{
  "name": "irenemonticelli-admin",
  "version": "0.1.0",
  "private": true,
  "description": "Sito Irene Monticelli + dashboard admin (Express + Prisma + SQLite)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
