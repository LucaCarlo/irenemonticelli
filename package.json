    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "method-override": "^3.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "sharp": "^0.33.5",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
